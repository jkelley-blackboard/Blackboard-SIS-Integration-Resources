          <personRecord>
            <sourcedGUID>
              <sourcedId>55556</sourcedId>
              <refAgentInstanceID>ILP</refAgentInstanceID>
            </sourcedGUID>

            <person>

              <!-- Formatted Name -->
              <formname>
                <formnameType>
                  <instanceIdentifier>
                    <language>en-US</language>
                    <textString>FormNameTypeID</textString>
                  </instanceIdentifier>
                  <instanceVocabulary>http://www.imsglobal.org/lis/pmsv2p0/formatnmetypevocabularyv1p0</instanceVocabulary>
                  <instanceValue>
                    <language>en-US</language>
                    <textString>Full</textString>
                  </instanceValue>
                </formnameType>
                <formattedName>
                  <language>en-US</language>
                  <textString>Firstblah Middleblah Lastblah</textString>  <!-- Full Name VALUE -->
                </formattedName>
              </formname>

              <!-- Structured Name -->
              <name>
                <nameType>
                  <instanceIdentifier>
                    <language>en-US</language>
                    <textString>NameTypeID</textString>
                  </instanceIdentifier>
                  <instanceVocabulary>http://www.imsglobal.org/lis/pmsv2p0/nametypevocabularyv1p0</instanceVocabulary>
                  <instanceValue>
                    <language>en-US</language>
                    <textString>Full</textString>
                  </instanceValue>
                </nameType>
                <partName>
                  <instanceIdentifier>
                    <language>en-US</language>
                    <textString>FirstNameID</textString>
                  </instanceIdentifier>
                  <instanceName>
                    <language>en-US</language>
                    <textString>First</textString>
                  </instanceName>
                  <instanceValue>
                    <language>en-US</language>
                    <textString>Firstblah</textString>  <!-- First Name VALUE -->
                  </instanceValue>
                </partName>
                <partName>
                  <instanceIdentifier>
                    <language>en-US</language>
                    <textString>LastNameID</textString>
                  </instanceIdentifier>
                  <instanceName>
                    <language>en-US</language>
                    <textString>Last</textString>
                  </instanceName>
                  <instanceValue>
                    <language>en-US</language>
                    <textString>Lastblah</textString>  <!-- Last Name VALUE -->
                  </instanceValue>
                </partName>
                <partName>
                  <instanceIdentifier>
                    <language>en-US</language>
                    <textString>MiddleNameID</textString>
                  </instanceIdentifier>
                  <instanceName>
                    <language>en-US</language>
                    <textString>Middle</textString>
                  </instanceName>
                  <instanceValue>
                    <language>en-US</language>
                    <textString>Middleblah</textString>  <!-- Middle Name VALUE -->
                  </instanceValue>
                </partName>
              </name>

              <!-- Contact Info -->
              <contactinfo>
                <contactinfoType>
                  <instanceIdentifier>
                    <language>en-US</language>
                    <textString>EmailPrimary</textString>
                  </instanceIdentifier>
                  <instanceValue>
                    <language>en-US</language>
                    <textString>EmailPrimary</textString>
                  </instanceValue>
                </contactinfoType>
                <contactinfoValue>
                  <language>en-US</language>
                  <textString>fl@blahblahblah.edu</textString>  <!-- Email Address VALUE -->
                </contactinfoValue>
              </contactinfo>

              <!-- Roles -->
              <!--
                A person may have one primary institution role and one or more secondary
                institution roles. The primary role is indicated by <primaryroletype>true</primaryroletype>.
                Secondary roles omit the <primaryroletype> element entirely.
              -->
              <roles>
                <enterpriserolesType>
                  <instanceIdentifier>
                    <language>en-US</language>
                    <textString>StudentInformationSystem</textString>
                  </instanceIdentifier>
                  <instanceValue>
                    <language>en-US</language>
                    <textString>StudentInformationSystem</textString>
                  </instanceValue>
                </enterpriserolesType>

                <!-- Primary Institution Role -->
                <institutionRole>
                  <institutionroletype>
                    <instanceIdentifier>
                      <language>en-US</language>
                      <textString>Instructor</textString>
                    </instanceIdentifier>
                    <instanceValue>
                      <language>en-US</language>
                      <textString>Instructor</textString>  <!-- Primary Institution Role VALUE -->
                    </instanceValue>
                  </institutionroletype>
                  <primaryroletype>true</primaryroletype>
                </institutionRole>

                <!-- Secondary Institution Role 1 -->
                <institutionRole>
                  <institutionroletype>
                    <instanceIdentifier>
                      <language>en-US</language>
                      <textString>Learner</textString>
                    </instanceIdentifier>
                    <instanceValue>
                      <language>en-US</language>
                      <textString>Learner</textString>  <!-- Secondary Institution Role VALUE -->
                    </instanceValue>
                  </institutionroletype>
