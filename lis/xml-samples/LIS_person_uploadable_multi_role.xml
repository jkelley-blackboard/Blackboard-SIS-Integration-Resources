                <!-- Secondary Institution Role 2 -->
                <institutionRole>
                  <institutionroletype>
                    <instanceIdentifier>
                      <language>en-US</language>
                      <textString>LSCO_Staff</textString>
                    </instanceIdentifier>
                    <instanceValue>
                      <language>en-US</language>
                      <textString>LSCO_Staff</textString>  <!-- Secondary Institution Role VALUE -->
                    </instanceValue>
                  </institutionroletype>
                </institutionRole>

                <!-- User ID -->
                <userId>
                  <userIdValue>
                    <language>en-US</language>
                    <textString>fl@blahblahblah.edu</textString>  <!-- User_ID / Logon ID VALUE -->
                  </userIdValue>
                  <userIdType>
                    <language>en-US</language>
                    <textString>Logon ID</textString>
                  </userIdType>
                  <password>
                    <language>en-US</language>
                    <textString/>
                  </password>
                </userId>
              </roles>

              <dataSource>ILP</dataSource>

              <!-- Extensions: institution-specific fields beyond the LIS standard -->
              <extension>
                <extensionField>
                  <fieldName>bannerSourcedId</fieldName>
                  <fieldValue>000</fieldValue>  <!-- Banner ID VALUE -->
                  <fieldType>String</fieldType>
                </extensionField>
                <extensionField>
                  <fieldName>bannerUserName</fieldName>
                  <fieldValue>userblah</fieldValue>  <!-- Banner Username VALUE -->
                  <fieldType>String</fieldType>
                </extensionField>
                <extensionField>
                  <fieldName>bannerUdcId</fieldName>
                  <fieldValue>XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX</fieldValue>  <!-- Banner UDC ID VALUE -->
                  <fieldType>String</fieldType>
                </extensionField>
              </extension>

            </person>
          </personRecord>
        </parameterValue>
      </parameterRecord>
    </parameterSet>
  </transactionRecord>
</bulkDataRecord>
