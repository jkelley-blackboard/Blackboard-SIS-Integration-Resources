<bulkDataRecord>
  <transactionRecord>
    <transactionOpIdentifier>tx1</transactionOpIdentifier>
    <serviceName>PersonManagementService</serviceName>
    <interfaceName>PersonManager</interfaceName>
    <operationName>replacePerson</operationName>
    <parameterSet>
      <parameterRecord>
